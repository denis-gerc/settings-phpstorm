<keymap version="1" name="Windows copy Proper Redo" parent="$default">
  <action id="$Redo">
    <keyboard-shortcut first-keystroke="shift ctrl z" />
    <keyboard-shortcut first-keystroke="shift alt back_space" />
    <keyboard-shortcut first-keystroke="ctrl y" />
  </action>
  <action id="CloseAllEditors">
    <keyboard-shortcut first-keystroke="shift ctrl alt end" />
  </action>
  <action id="CloseAllEditorsButActive">
    <keyboard-shortcut first-keystroke="shift ctrl alt home" />
  </action>
  <action id="EditorDeleteLine" />
  <action id="EditorJoinLines" />
  <action id="ImplementMethods" />
  <action id="InsertLiveTemplate" />
  <action id="NewScratchFile">
    <keyboard-shortcut first-keystroke="shift ctrl alt insert" />
    <keyboard-shortcut first-keystroke="alt n" />
  </action>
  <action id="SearchEverywhere">
    <keyboard-shortcut first-keystroke="shift z" />
  </action>
  <action id="UsageFiltering.Imports" />
  <action id="org.intellij.plugins.markdown.ui.actions.styling.ToggleItalicAction" />
</keymap>